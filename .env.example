# AnvoIO Core Monitor Configuration

# ============================================================================
# Chain Configuration (comma-separated list of chain IDs to monitor)
# ============================================================================
CHAINS=libre_mainnet,libre_testnet

# Libre Mainnet
LIBRE_MAINNET_SHIP_URL=wss://api.libre.pdx.cryptobloks.io/
LIBRE_MAINNET_SHIP_FAILOVER_URL=wss://api.libre.iad.cryptobloks.io/
LIBRE_MAINNET_API_URL=https://api.libre.pdx.cryptobloks.io
LIBRE_MAINNET_HYPERION_URL=https://api.libre.cryptobloks.io/v2
LIBRE_MAINNET_CHAIN_ID=38b1d7815474d0c60683ecbea321d723e83f5da6ae5f1c1f9fecc69d9ba96465
LIBRE_MAINNET_SCHEDULE_SIZE=21
LIBRE_MAINNET_BLOCKS_PER_BP=12
LIBRE_MAINNET_BLOCK_TIME_MS=500

# Libre Testnet
LIBRE_TESTNET_SHIP_URL=wss://api.testnet.libre.pdx.cryptobloks.io/
LIBRE_TESTNET_SHIP_FAILOVER_URL=wss://api.testnet.libre.iad.cryptobloks.io/
LIBRE_TESTNET_API_URL=https://api.testnet.libre.pdx.cryptobloks.io
LIBRE_TESTNET_HYPERION_URL=https://api.testnet.libre.cryptobloks.io/v2
LIBRE_TESTNET_CHAIN_ID=b64646740308df2ee06c6b72f34c0f7fa066d940e831f752db2006fcc2b78dee
LIBRE_TESTNET_SCHEDULE_SIZE=21
LIBRE_TESTNET_BLOCKS_PER_BP=12
LIBRE_TESTNET_BLOCK_TIME_MS=500

# ============================================================================
# Telegram Alerting
# ============================================================================
TELEGRAM_ENABLED=false
TELEGRAM_API_KEY=
TELEGRAM_LIBRE_MAINNET_STATUS_CHAT_ID=
TELEGRAM_LIBRE_MAINNET_ALERT_CHAT_ID=
TELEGRAM_LIBRE_TESTNET_STATUS_CHAT_ID=
TELEGRAM_LIBRE_TESTNET_ALERT_CHAT_ID=

# ============================================================================
# Slack Alerting
# ============================================================================
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=

# ============================================================================
# API Server
# ============================================================================
API_PORT=3000
API_HOST=0.0.0.0
# Host port mapping for Docker (container always listens on API_PORT internally)
MONITOR_PORT=3100

# ============================================================================
# Data Retention
# ============================================================================
RETENTION_DAYS=548

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=info
